# .gitignore

# Security: Exclude credentials and tokens
client_secrets.json
token.json
.env

# Virtual Environment: Never commit this folder
venv/
.venv/

# Python cache files
__pycache__/
*.pyc

# IDE/Editor specific configuration
.vscode/
.idea/

# Database files: Should be generated by the script, not committed
*.db
*.sqlite3

# Code Design Files
BigDataBall-Ingestion-Pipeline-Setup-Guide.md

# Additional files to ignore (workspace, SQL queries, etc.)
Python-Bigdataball-Project.code-workspace

# SQL query files unused in scripts
queries/
*.sql
.devdbrc

# Claude Code executor worktrees (ephemeral, never commit)
.claude/worktrees/

# Transient codebase-scan artifact (regenerated by the mapping skill)
docs/codebase/.codebase-scan.txt

# One-off extraction scripts for CSVs (not part of the main ingestion pipeline)
csv-extraction-scripts/